<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]

  # Force SPA handling for demo routes even if legacy demo/ folders exist in the web root
  RewriteRule ^demo(/.*)?$ /index.html [L]
  
  # Exclude static directories and files from SPA rewriting
  RewriteRule ^(brochures|public|clipboard|kids-goexplore|os3grid|dadchef)(/.*)?$ - [L]
  RewriteRule \.(pdf|png|jpg|jpeg|gif|css|js|svg|woff|woff2|ttf|eot)$ - [L]
  
  # Rewrite remaining requests to index.html for SPA routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
